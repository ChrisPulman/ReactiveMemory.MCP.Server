<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>CP.ReactiveMemory.MCP.Server</AssemblyName>
    <RootNamespace>ReactiveMemory.MCP.Server</RootNamespace>
    <PackageId>CP.ReactiveMemory.Mcp.Server</PackageId>
    <Title>ReactiveMemory MCP Server</Title>
    <Description>ReactiveMemory MCP server with vector-compatible storage, mining pipeline, and temporal knowledge graph.</Description>
    <PackageTags>ReactiveMemory;MCP;Model Context Protocol;C#;dotnet;knowledge graph;vector search</PackageTags>
    <PackAsTool>true</PackAsTool>
    <PackageType>McpServer</PackageType>
    <ToolCommandName>reactivememory-mcp-server</ToolCommandName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="ModelContextProtocol" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ReactiveMemory.MCP.Core\CP.ReactiveMemory.MCP.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="" Link="README.md" />
    <None Include="..\..\Images\reactive-memory-icon.png" Pack="true" PackagePath="Images\" Link="Images\reactive-memory-icon.png" />
    <None Include="..\..\Images\reactive-memory-logo.png" Pack="true" PackagePath="Images\" Link="Images\reactive-memory-logo.png" />
    <None Include="..\..\skills\reactive-memory\SKILL.md" Pack="true" PackagePath="skills\reactive-memory\" Link="skills\reactive-memory\SKILL.md" />
    <None Include="..\..\.mcp\server.json" Pack="true" PackagePath=".mcp\server.json" Link=".mcp\server.json" />
  </ItemGroup>
</Project>
